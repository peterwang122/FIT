APP_NAME=FIT API
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api/v1

DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/fit
REDIS_URL=redis://127.0.0.1:6379/0

# Auth / session
AUTH_SESSION_COOKIE_NAME=fit_session
AUTH_SESSION_TTL_SECONDS=604800
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# SMS login
AUTH_SMS_CODE_TTL_SECONDS=300
AUTH_SMS_RESEND_COOLDOWN_SECONDS=60
AUTH_SMS_DAILY_LIMIT=10
AUTH_SMS_MAX_ATTEMPTS=5

# Built-in accounts
ROOT_USERNAME=root
ROOT_PASSWORD=change-me-root-password
GUEST_USERNAME=guest
GUEST_PASSWORD=change-me-guest-password

# Aliyun SMS verify-code service (Dypnsapi)
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=速通互联验证码
ALIYUN_SMS_TEMPLATE_CODE=100001

# Optional backward-compatible aliases; leave empty if using ALIBABA_CLOUD_* above
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=

# Current DB field mapping is already built into code defaults.
# Override only when your actual schema differs.
# STOCK_TABLE_NAME=stock_daily_data
# STOCK_CODE_COLUMN=stock_code
# STOCK_DATE_COLUMN=trade_date
# STOCK_OPEN_COLUMN=open_price
# STOCK_HIGH_COLUMN=high_price
# STOCK_LOW_COLUMN=low_price
# STOCK_CLOSE_COLUMN=close_price
# STOCK_PRE_CLOSE_COLUMN=pre_close_price
# STOCK_CHANGE_COLUMN=price_change_amount
# STOCK_PCT_CHG_COLUMN=price_change_rate
# STOCK_VOL_COLUMN=volume
# STOCK_AMOUNT_COLUMN=turnover_amount
# STOCK_PE_TTM_COLUMN=pe_ttm
# STOCK_PB_COLUMN=pb
# STOCK_TOTAL_MARKET_VALUE_COLUMN=total_market_value
# STOCK_CIRCULATING_MARKET_VALUE_COLUMN=circulating_market_value

# Stock symbol source
# STOCK_BASIC_INFO_TABLE_NAME=stock_info_all
# STOCK_BASIC_INFO_CODE_COLUMN=stock_code
# STOCK_BASIC_INFO_NAME_COLUMN=stock_name

COLLECTOR_BASE_URL=http://127.0.0.1:9000
COLLECTOR_TIMEOUT_SECONDS=30
COLLECTOR_TASK_SOFT_TIME_LIMIT_SECONDS=45
COLLECTOR_TASK_TIME_LIMIT_SECONDS=60
COLLECTOR_TASK_MAX_RETRIES=3
COLLECTOR_TASK_RETRY_BACKOFF_SECONDS=5

STOCK_TEMP_SERVICE_BASE_URL=http://127.0.0.1:8786
STOCK_TEMP_SERVICE_TIMEOUT_SECONDS=1800
STOCK_TEMP_TASK_SOFT_TIME_LIMIT_SECONDS=1800
STOCK_TEMP_TASK_TIME_LIMIT_SECONDS=2100
STOCK_TEMP_TASK_MAX_RETRIES=5
STOCK_TEMP_DAILY_SERVICE_TIMEOUT_SECONDS=7200
STOCK_TEMP_DAILY_TASK_SOFT_TIME_LIMIT_SECONDS=7200
STOCK_TEMP_DAILY_TASK_TIME_LIMIT_SECONDS=7500
STOCK_TEMP_DAILY_TASK_MAX_RETRIES=3

TASK_IDEMPOTENCY_TTL_SECONDS=3600
COLLECTOR_DEDUPE_LOCK_TTL_SECONDS=120

FLOWER_URL=http://127.0.0.1:5555

# SMTP for scheduled notification emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FIT 股票量化系统
GITHUB_TOKEN=

# To enable scheduled tasks in production/dev, run both:
# celery -A app.workers.celery_app worker --loglevel=info -P solo
# celery -A app.workers.celery_app beat --loglevel=info

# Comma-separated list; "*" is fine for local development.
CORS_ALLOW_ORIGINS=*
